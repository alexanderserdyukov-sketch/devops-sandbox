pipeline {
    agent {
        dockerfile {
            filename 'Dockerfile.build'
            dir 'python/simple-math-uv'
        }
    }
    environment {
        UV_CACHE_DIR = "${WORKSPACE}/.uv-cache"
    }
    stages {
        stage('Lint') {
            steps {
                dir('python/simple-math-uv') {
                    sh 'uvx ruff check'
                }
            }
        }
        stage('Test') {
            steps {
                dir('python/simple-math-uv') {
                    sh 'uv run pytest --junitxml=results.xml'
                }
            }
            post {
                always {
                    junit 'python/simple-math-uv/results.xml'
                }
            }
        }
        stage('Build') {
            steps {
                dir('python/simple-math-uv') {
                    sh 'uv build'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'python/simple-math-uv/dist/*', fingerprint: true
                }
            }        
        }
    }
}